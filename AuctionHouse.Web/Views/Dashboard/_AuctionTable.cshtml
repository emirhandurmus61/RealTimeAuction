@model IEnumerable<AuctionHouse.Core.DTOs.AuctionSummaryDto>
@{
    static (string text, string css, bool live) StatusBadge(AuctionHouse.Core.Entities.AuctionStatus s) => s switch
    {
        AuctionHouse.Core.Entities.AuctionStatus.Active => ("Canlı", "bg-success", true),
        AuctionHouse.Core.Entities.AuctionStatus.Scheduled => ("Planlandı", "bg-secondary", false),
        AuctionHouse.Core.Entities.AuctionStatus.Ended => ("Bitti", "bg-dark", false),
        AuctionHouse.Core.Entities.AuctionStatus.Cancelled => ("İptal", "bg-danger", false),
        _ => ("?", "bg-secondary", false)
    };
}

@if (!Model.Any())
{
    <div class="alert alert-info">Burada henüz kayıt yok.</div>
}
else
{
    <div class="table-wrap">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th class="text-end">Güncel Fiyat</th>
                    <th>Bitiş</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    var badge = StatusBadge(a.Status);
                    <tr>
                        <td class="fw-bold">@a.Title</td>
                        <td>@(a.CategoryName ?? "—")</td>
                        <td class="text-end fw-bold" style="font-family: var(--ff-mono);">@a.CurrentPrice.ToString("N2") ₺</td>
                        <td class="text-muted">@a.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="badge @badge.css">
                                @if (badge.live) { <span class="live-dot"></span> }@badge.text
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-controller="Auctions" asp-action="Details" asp-route-id="@a.Id"
                               class="btn btn-sm btn-outline-primary">Görüntüle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
