@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="px-4 py-5 my-3 text-center">
    <h1 class="display-4 fw-bold">🔨 RealTimeAuction</h1>
    <div class="col-lg-7 mx-auto">
        <p class="lead mb-4">
            Gerçek zamanlı, çok kullanıcılı açık artırma platformu.
            Bir teklif verildiği anda fiyat, geri sayım ve izleyici sayısı
            herkesin ekranında anlık güncellenir.
        </p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-controller="Auctions" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3">
                Açık Artırmalara Göz At
            </a>
        </div>
    </div>
</div>
