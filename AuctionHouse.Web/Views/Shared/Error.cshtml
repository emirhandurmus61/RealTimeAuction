@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="hero" style="padding-bottom:2rem;">
    <span class="hero-eyebrow" style="color: var(--danger); border-color: rgba(255,93,108,.3);">Bir şeyler ters gitti</span>
    <h1 class="grad-text" style="font-size: clamp(2.2rem,6vw,3.6rem);">İsteğiniz işlenemedi</h1>
    <p class="lead">Beklenmedik bir hata oluştu. Lütfen tekrar deneyin ya da ana sayfaya dönün.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">Ana Sayfaya Dön</a>
</div>

@if (Model.ShowRequestId)
{
    <div class="card">
        <div class="card-body">
            <strong>İstek No:</strong> <code style="font-family: var(--ff-mono); color: var(--amber-300);">@Model.RequestId</code>
        </div>
    </div>
}
