@model AuctionHouse.Core.Entities.Auction
@using System.Security.Claims
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = Model.Title;
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var isActive = Model.Status == AuctionHouse.Core.Entities.AuctionStatus.Active;
    var isEnded = Model.Status == AuctionHouse.Core.Entities.AuctionStatus.Ended;

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isSeller = currentUserId is not null && currentUserId == Model.SellerId;
    var isWinner = currentUserId is not null && currentUserId == Model.WinnerId;
    var hasWinner = !string.IsNullOrEmpty(Model.WinnerId);
}

@if (TempData["Created"] is string createdMsg)
{
    <div class="alert alert-info">@createdMsg</div>
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Açık Artırmalar</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-7">
        @{
            var images = Model.Images.OrderBy(i => i.SortOrder).ToList();
        }
        @if (images.Any())
        {
            <div class="gallery">
                <div class="gallery-main">
                    <img id="galleryMain" src="@images[0].Url" alt="@Model.Title" />
                </div>
                @if (images.Count > 1)
                {
                    <div class="gallery-thumbs">
                        @for (var i = 0; i < images.Count; i++)
                        {
                            <button type="button" class="gallery-thumb @(i == 0 ? "active" : "")"
                                    data-src="@images[i].Url" aria-label="Görsel @(i + 1)">
                                <img src="@images[i].Url" alt="" loading="lazy" />
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <h1 class="mb-2">@Model.Title</h1>
        @if (Model.Category is not null)
        {
            <span class="badge bg-light text-dark mb-3">@Model.Category.Name</span>
        }
        <p class="lead">@Model.Description</p>

        <div class="card mt-4">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Açılış Fiyatı</dt>
                    <dd class="col-sm-8" style="font-family: var(--ff-mono);">@Model.StartPrice.ToString("N2") ₺</dd>

                    <dt class="col-sm-4">Min. Artış</dt>
                    <dd class="col-sm-8" style="font-family: var(--ff-mono);">@Model.MinIncrement.ToString("N2") ₺</dd>

                    <dt class="col-sm-4">Satıcı</dt>
                    <dd class="col-sm-8">@(Model.Seller?.DisplayName ?? Model.Seller?.Email ?? "—")</dd>

                    <dt class="col-sm-4">Bitiş</dt>
                    <dd class="col-sm-8">@Model.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="bid-panel">
            <div class="card-body text-center position-relative" style="z-index:1;">
                <div class="d-flex justify-content-between mb-4">
                    <span class="badge bg-info">
                        <span id="viewerCount">0</span> izleyici
                    </span>
                    <span id="countdown" class="badge bg-warning text-dark">--:--</span>
                </div>

                <div class="price-label mb-1">Güncel Teklif</div>
                <div id="currentPrice" class="display-5 fw-bold mb-4"
                     data-value="@Model.CurrentPrice">
                    @Model.CurrentPrice.ToString("N2") ₺
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div id="bidArea">
                        <div class="input-group mb-2">
                            <input type="number" step="0.01" id="bidAmount" class="form-control"
                                   placeholder="Teklif tutarı (₺)" />
                            <button id="bidButton" class="btn btn-primary">Teklif Ver</button>
                        </div>
                        <div id="bidFeedback" class="small"></div>
                    </div>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login"
                       asp-route-returnUrl="@Url.Action("Details", new { id = Model.Id })"
                       class="btn btn-primary w-100">Teklif vermek için giriş yap</a>
                }
            </div>
        </div>

        @* --- Kazananla / satıcıyla iletişim: yalnızca ilan bittiğinde ve ilgili taraflara --- *@
        @if (isEnded && hasWinner && (isSeller || isWinner))
        {
            <div class="contact-card">
                @if (isSeller)
                {
                    <div class="contact-head"><span class="badge bg-success">Satış tamamlandı</span></div>
                    <p class="text-muted small mb-3">Bu lotu kazanan alıcının iletişim bilgileri aşağıdadır. Teslimat ve ödeme için iletişime geçebilirsiniz.</p>
                    <div class="contact-row">
                        <span class="k">Kazanan</span>
                        <span class="v">@(Model.Winner?.DisplayName ?? "—")</span>
                    </div>
                    <div class="contact-row">
                        <span class="k">E-posta</span>
                        <span class="v"><a href="mailto:@Model.Winner?.Email">@Model.Winner?.Email</a></span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Winner?.PhoneNumber))
                    {
                        <div class="contact-row">
                            <span class="k">Telefon</span>
                            <span class="v"><a href="tel:@Model.Winner?.PhoneNumber">@Model.Winner?.PhoneNumber</a></span>
                        </div>
                    }
                    <div class="contact-row">
                        <span class="k">Satış bedeli</span>
                        <span class="v" style="font-family: var(--ff-mono);">@Model.CurrentPrice.ToString("N2") ₺</span>
                    </div>
                }
                else
                {
                    <div class="contact-head"><span class="badge bg-warning text-dark">Tebrikler, kazandınız</span></div>
                    <p class="text-muted small mb-3">Bu lotu kazandınız. Teslimat ve ödeme için satıcıyla iletişime geçin.</p>
                    <div class="contact-row">
                        <span class="k">Satıcı</span>
                        <span class="v">@(Model.Seller?.DisplayName ?? "—")</span>
                    </div>
                    <div class="contact-row">
                        <span class="k">E-posta</span>
                        <span class="v"><a href="mailto:@Model.Seller?.Email">@Model.Seller?.Email</a></span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Seller?.PhoneNumber))
                    {
                        <div class="contact-row">
                            <span class="k">Telefon</span>
                            <span class="v"><a href="tel:@Model.Seller?.PhoneNumber">@Model.Seller?.PhoneNumber</a></span>
                        </div>
                    }
                    <div class="contact-row">
                        <span class="k">Ödenecek tutar</span>
                        <span class="v" style="font-family: var(--ff-mono);">@Model.CurrentPrice.ToString("N2") ₺</span>
                    </div>
                }
            </div>
        }

        <h5 class="section-title mt-4 mb-3">Teklif Geçmişi · <span id="bidCount">@Model.Bids.Count</span></h5>
        <ul id="bidList" class="list-group">
            @foreach (var bid in Model.Bids)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>@(bid.Bidder?.DisplayName ?? bid.Bidder?.Email ?? "Anonim")</span>
                    <strong style="font-family: var(--ff-mono);">@bid.Amount.ToString("N2") ₺</strong>
                </li>
            }
        </ul>
        <p id="noBids" class="text-muted small mt-2 @(Model.Bids.Any() ? "d-none" : "")">Henüz teklif yok — ilk teklifi sen ver.</p>
    </div>
</div>

@section Scripts {
    <script>
        // --- Galeri: thumbnail tıklayınca ana görseli değiştir ---
        (function () {
            const main = document.getElementById("galleryMain");
            if (!main) return;
            document.querySelectorAll(".gallery-thumb").forEach(btn => {
                btn.addEventListener("click", () => {
                    main.src = btn.dataset.src;
                    document.querySelectorAll(".gallery-thumb").forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                });
            });
        })();
    </script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        const auctionId = @Model.Id;
        // EndTime sunucuda UTC tutulur; ISO string'e Z ekleyerek UTC olarak parse et.
        const endTimeUtc = new Date("@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")Z");
        const isActive = @(isActive ? "true" : "false");
        const antiforgeryToken = "@token";

        function parseUtc(s) {
            return new Date(s.endsWith("Z") ? s : s + "Z");
        }

        // --- Server-authoritative geri sayım ---
        // Bitiş zamanı sunucudan gelir; istemci yalnızca sayar.
        const countdownEl = document.getElementById("countdown");
        let currentEndTime = endTimeUtc;

        function renderCountdown() {
            const diff = currentEndTime - new Date();
            if (diff <= 0) {
                countdownEl.textContent = "Bitti";
                countdownEl.className = "badge bg-dark";
                return;
            }
            const totalSec = Math.floor(diff / 1000);
            const h = Math.floor(totalSec / 3600);
            const m = Math.floor((totalSec % 3600) / 60);
            const s = totalSec % 60;
            const pad = n => String(n).padStart(2, "0");
            countdownEl.textContent = h > 0 ? `${h}:${pad(m)}:${pad(s)}` : `${pad(m)}:${pad(s)}`;
            // Son 10 sn vurgusu
            countdownEl.className = totalSec <= 10 ? "badge bg-danger" : "badge bg-warning text-dark";
        }
        renderCountdown();
        setInterval(renderCountdown, 1000);

        function fmt(n) {
            return Number(n).toLocaleString("tr-TR", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " ₺";
        }

        // --- SignalR canlı bağlantı ---
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/auction")
            .withAutomaticReconnect()
            .build();

        connection.on("ViewerCountChanged", e => {
            if (e.auctionId === auctionId)
                document.getElementById("viewerCount").textContent = e.viewerCount;
        });

        connection.on("BidPlaced", e => {
            if (e.auctionId !== auctionId) return;
            // Canlı fiyat
            const priceEl = document.getElementById("currentPrice");
            priceEl.textContent = fmt(e.newPrice);
            priceEl.dataset.value = e.newPrice;
            priceEl.classList.add("text-success");
            setTimeout(() => priceEl.classList.remove("text-success"), 800);

            // Sunucu bitiş zamanını da gönderir -> sayaç senkronu (anti-sniping dahil).
            if (e.endTime) currentEndTime = parseUtc(e.endTime);

            // Teklif geçmişine ekle
            const list = document.getElementById("bidList");
            const li = document.createElement("li");
            li.className = "list-group-item d-flex justify-content-between list-group-item-success";
            li.innerHTML = `<span>${e.bidderName ?? "Anonim"}</span><strong style="font-family: var(--ff-mono);">${fmt(e.newPrice)}</strong>`;
            list.prepend(li);
            document.getElementById("noBids").classList.add("d-none");
            const cnt = document.getElementById("bidCount");
            cnt.textContent = parseInt(cnt.textContent || "0") + 1;
        });

        connection.on("AuctionExtended", e => {
            if (e.auctionId !== auctionId) return;
            currentEndTime = parseUtc(e.newEndTime);
            countdownEl.classList.add("bg-danger");
        });

        connection.on("AuctionEnded", e => {
            if (e.auctionId !== auctionId) return;
            countdownEl.textContent = "Bitti";
            countdownEl.className = "badge bg-dark";
            const area = document.getElementById("bidArea");
            if (area) area.innerHTML = `<div class="alert alert-dark mb-0">Açık artırma sona erdi. Kazanan: ${e.winnerName ?? "—"}</div>`;
        });

        connection.on("Outbid", e => {
            if (e.auctionId !== auctionId) return;
            const fb = document.getElementById("bidFeedback");
            if (fb) { fb.className = "small text-danger"; fb.textContent = "Teklifiniz geçildi! Yeni fiyat: " + fmt(e.newPrice); }
        });

        connection.start()
            .then(() => connection.invoke("JoinAuction", auctionId))
            .catch(err => console.error("SignalR bağlantı hatası:", err));

        // --- Teklif gönderme (AJAX) ---
        const bidButton = document.getElementById("bidButton");
        if (bidButton) {
            bidButton.addEventListener("click", async () => {
                const amount = parseFloat(document.getElementById("bidAmount").value);
                const fb = document.getElementById("bidFeedback");
                if (isNaN(amount)) { fb.className = "small text-danger"; fb.textContent = "Geçerli bir tutar girin."; return; }

                bidButton.disabled = true;
                try {
                    const res = await fetch("@Url.Action("PlaceBid")", {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded", "RequestVerificationToken": antiforgeryToken },
                        body: new URLSearchParams({ id: auctionId, amount: amount })
                    });
                    const data = await res.json();
                    fb.className = data.success ? "small text-success" : "small text-danger";
                    fb.textContent = data.message;
                    if (data.success) document.getElementById("bidAmount").value = "";
                } catch (err) {
                    fb.className = "small text-danger";
                    fb.textContent = "Bir hata oluştu, tekrar deneyin.";
                } finally {
                    bidButton.disabled = false;
                }
            });
        }
    </script>
}
