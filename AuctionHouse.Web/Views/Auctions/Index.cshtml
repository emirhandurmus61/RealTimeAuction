@model IEnumerable<AuctionHouse.Core.Entities.Auction>
@{
    ViewData["Title"] = "Açık Artırmalar";

    static (string text, string css, bool live) StatusBadge(AuctionHouse.Core.Entities.AuctionStatus s) => s switch
    {
        AuctionHouse.Core.Entities.AuctionStatus.Active => ("Canlı", "bg-success", true),
        AuctionHouse.Core.Entities.AuctionStatus.Scheduled => ("Planlandı", "bg-secondary", false),
        AuctionHouse.Core.Entities.AuctionStatus.Ended => ("Bitti", "bg-dark", false),
        AuctionHouse.Core.Entities.AuctionStatus.Cancelled => ("İptal", "bg-danger", false),
        _ => ("?", "bg-secondary", false)
    };
}

<div class="page-head d-flex flex-wrap justify-content-between align-items-end gap-2">
    <div>
        <h1 class="mb-1">Açık Artırmalar</h1>
        <p class="text-muted mb-0">Aktif odaları keşfet, teklifini ver, çekiç düşene kadar takipte kal.</p>
    </div>
    <span class="badge bg-info">@Model.Count() ilan</span>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz açık artırma yok. Yakında yeni ilanlar burada listelenecek.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var a in Model)
        {
            var badge = StatusBadge(a.Status);
            <div class="col">
                <div class="card auction-card h-100">
                    @{
                        var cover = a.Images.OrderBy(i => i.SortOrder).FirstOrDefault();
                    }
                    @if (cover is not null)
                    {
                        <div class="auction-cover">
                            <img src="@cover.Url" alt="@a.Title" loading="lazy" />
                            @if (a.Images.Count > 1)
                            {
                                <span class="cover-count">@a.Images.Count fotoğraf</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="auction-cover is-placeholder">Görsel yok</div>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                            <h5 class="card-title mb-0">@a.Title</h5>
                            <span class="badge @badge.css flex-shrink-0">
                                @if (badge.live) { <span class="live-dot"></span> }@badge.text
                            </span>
                        </div>
                        @if (a.Category is not null)
                        {
                            <div class="mb-2"><span class="badge bg-light text-dark">@a.Category.Name</span></div>
                        }
                        <p class="card-text small flex-grow-1">@a.Description</p>

                        <div class="mt-3">
                            <div class="price-label">Güncel teklif</div>
                            <div class="fs-4 fw-bold text-primary" style="font-family: var(--ff-mono);">
                                @a.CurrentPrice.ToString("N2") ₺
                            </div>
                        </div>
                        <div class="small text-muted mt-1">
                            Bitiş: @a.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-outline-primary btn-sm w-100">
                            Detay &amp; Teklif Ver
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
